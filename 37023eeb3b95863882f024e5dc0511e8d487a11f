      "side": 1,
      "message": "[Critical] Line 255: Critical privacy/authorization issue: transformSwarmMessages() invokes every loaded ChatHandler for every loaded conversation, regardless of the conversation allow/deny state. This lets disabled plugins read and mutate message history for conversations where the user did not enable them. Filter to handlers active for {accountId, conversationId}, reusing the same allow/deny/always activation rules as publishMessage().\n```suggestion\nvoid\nChatServicesManager::transformSwarmMessages(std::vector\u003clibjami::SwarmMessage\u003e\u0026 messages,\n                                            const std::string\u0026 accountId,\n                                            const std::string\u0026 conversationId)\n{\n    std::pair\u003cstd::string, std::string\u003e key(accountId, conversationId);\n    for (auto\u0026 handler : chatHandlers_) {\n        const auto handlerName \u003d handler-\u003egetChatHandlerDetails().at(\"name\");\n        const auto toggled \u003d chatHandlerToggled_[key].find((uintptr_t) handler.get())\n                             !\u003d chatHandlerToggled_[key].end();\n        const auto allowed \u003d allowDenyList_[key].find(handlerName) !\u003d allowDenyList_[key].end()\n                             \u0026\u0026 allowDenyList_[key][handlerName];\n        if (toggled || allowed)\n            handler-\u003etransformSwarmMessages(messages, accountId, conversationId);\n    }\n}\n```",
      "revId": "37023eeb3b95863882f024e5dc0511e8d487a11f",
