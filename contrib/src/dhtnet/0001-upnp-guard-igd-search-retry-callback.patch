From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Copilot <223556219+Copilot@users.noreply.github.com>
Date: Wed, 22 Jul 2026 23:06:45 +0000
Subject: [PATCH] upnp: guard IGD search retry callback

Avoid dereferencing PUPnP after destruction when the IGD search retry timer
fires during shutdown.
---
 src/upnp/protocol/pupnp/pupnp.cpp | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/src/upnp/protocol/pupnp/pupnp.cpp b/src/upnp/protocol/pupnp/pupnp.cpp
index 0000000..0000000 100644
--- a/src/upnp/protocol/pupnp/pupnp.cpp
+++ b/src/upnp/protocol/pupnp/pupnp.cpp
@@ -368,11 +368,13 @@ PUPnP::searchForIgd()
         }
 
         searchForIgdTimer_.expires_after(IGD_SEARCH_RETRY_INTERVAL);
-        searchForIgdTimer_.async_wait([this](const std::error_code& ec) {
+        searchForIgdTimer_.async_wait([w = weak_from_this()](const std::error_code& ec) {
             if (ec == asio::error::operation_aborted) {
                 return;
             }
-            searchForIgd();
+            if (auto self = w.lock()) {
+                self->searchForIgd();
+            }
         });
     }
 }
