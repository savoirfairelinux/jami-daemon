{
    "name": "opendht",
    "version": "4.2.0",
    "url": "https://github.com/savoirfairelinux/opendht/archive/v__VERSION__.tar.gz",
    "deps": [
        "argon2",
        "asio",
        "gnutls",
        "jsoncpp",
        "msgpack",
        "restinio",
        "simdutf"
    ],
    "use_cmake": true,
    "defines": [
        "CMAKE_CXX_STANDARD=20",
        "BUILD_SHARED_LIBS=0",
        "BUILD_TESTING=0",
        "OPENDHT_DOCUMENTATION=0",
        "OPENDHT_SHARED=0",
        "OPENDHT_PROXY_CLIENT=1",
        "OPENDHT_PROXY_SERVER=1",
        "OPENDHT_PUSH_NOTIFICATIONS=1",
        "OPENDHT_TOOLS=0",
        "CMAKE_MSVC_RUNTIME_LIBRARY=MultiThreadedDLL"
    ],
    "patches": [
        "0001-cmake-fix-jami-contrib-linking.patch"
    ],
    "win_patches": [],
    "project_paths": [],
    "with_env": "",
    "custom_scripts": {
        "pre_build": [
            "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$p='src/dht.cpp'; $s=Get-Content $p -Raw; $r='std::bind\\s*\\(\\s*&Dht::expireStorage\\s*,\\s*this\\s*,\\s*std::cref\\s*\\(\\s*([^()]+?)\\s*\\)\\s*\\)'; $patched=[regex]::Replace($s, $r, 'std::bind(&Dht::expireStorage, this, $1)'); if ($patched -eq $s) { throw 'Dht::expireStorage bind not found' }; Set-Content $p $patched -NoNewline\""
        ],
        "build": [],
        "post_build": []
    }
}
